# ============================================================================
# Environment Configuration
# ============================================================================
# Copy this file to .env and update with your actual credentials
# ============================================================================

# Database Configuration
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_password_here
DB_NAME=fashion_recommendation_db
DB_PORT=3306
DB_SSL_STRICT=true
DB_SSL_VERIFY_IDENTITY=true
DB_SSL_CA_PATH=
DB_SSL_CA_CERT=

# Flask Configuration
FLASK_ENV=development
FLASK_DEBUG=True
FLASK_HOST=0.0.0.0
FLASK_PORT=5000

# Security
SECRET_KEY=your-secret-key-here-change-in-production

# API Configuration
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# Groq
GROQ_API_KEY=your_groq_key_here
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
GROQ_MAX_RETRIES=2
GROQ_RETRY_BASE_SEC=0.7
GROQ_REQUEST_TIMEOUT_SEC=18
GROQ_MODEL_CANDIDATES=

# LLM Provider (openrouter|groq)
LLM_PROVIDER=openrouter

# OpenRouter (recommended for text + vision)
OPENROUTER_API_KEY=your_openrouter_key_here
OPENROUTER_TEXT_MODEL=meta-llama/llama-3.3-70b-instruct
OPENROUTER_VISION_MODEL=google/gemini-2.0-flash-001
OPENROUTER_MODEL_CANDIDATES=
OPENROUTER_MAX_RETRIES=2
OPENROUTER_RETRY_BASE_SEC=0.7
OPENROUTER_REQUEST_TIMEOUT_SEC=18
OPENROUTER_SITE_URL=http://localhost:3000
OPENROUTER_APP_NAME=Virtual Fit AI Studio

# VTON Provider Selection (active)
VTON_PROVIDER=seededit
ARK_API_KEY=your_ark_api_key_here
SEEDEDIT_API_KEY=
ARK_IMAGE_GENERATIONS_ENDPOINT=https://ark.ap-southeast.bytepluses.com/api/v3/images/generations
SEEDEDIT_I2I_ENDPOINT=https://ark.ap-southeast.bytepluses.com/api/v3/images/generations
SEEDEDIT_MODEL=seededit-3-0-i2i-250628
SEEDEDIT_AUTH_MODES=bearer
SEEDEDIT_RESPONSE_FORMAT=url
SEEDEDIT_SIZE=adaptive
SEEDEDIT_SEED=21
SEEDEDIT_GUIDANCE_SCALE=5.5
SEEDEDIT_WATERMARK=true
VTON_MAX_LATENCY_SEC=28
VTON_VALIDATION_ENABLED=true
VTON_VALIDATION_REQUIRED=true
VTON_VALIDATION_VISION_MODEL=google/gemini-2.0-flash-001
VTON_VALIDATION_TIMEOUT_SEC=5
VTON_VALIDATION_MAX_RETRIES=1
VTON_VALIDATION_IMAGE_MAX_SIDE=640
VTON_VALIDATION_JPEG_QUALITY=72
VTON_OUTPUT_FIRST=true
VTON_OUTPUT_FIRST_EXTRA_SEC=180

# Logging
LOG_LEVEL=INFO
